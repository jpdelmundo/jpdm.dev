{
  "type": "module",
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "debug": "tsx watch --inspect src/app.ts",
    "build": "rm -rf dist *.tsbuildinfo ../shared/dist ../shared/*.tsbuildinfo && tsc -b tsconfig.build.json && tsc-alias -p tsconfig.alias.json",
    "migrate": "tsx src/migrate.ts",
    "migrate:prod": "node dist/migrate.js",
    "preload": "node -e \"import('geolite2-redist').then(geolite => geolite.downloadDbs())\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@project/shared": "^1.0.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "file-type": "^21.0.0",
    "geolite2-redist": "^3.1.2",
    "image-size": "^2.0.2",
    "jsonwebtoken": "^9.0.2",
    "maxmind": "^5.0.5",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.4",
    "openai": "^6.16.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.16.3",
    "sharp": "^0.34.5",
    "tsx": "^4.20.3",
    "uuid": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/maxmind": "^2.0.4",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.9",
    "@types/nodemailer": "^7.0.3",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.15.5",
    "tsc-alias": "^1.8.16"
  }
}
