{
  "references": [
    {
      "path": "../shared/tsconfig.build.json"
    }
  ],
  "compilerOptions": {
    "composite": true,
    "esModuleInterop": true,
    "rootDir": "src",
    "outDir": "dist",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2020",
    "sourceMap": true,
    "declaration": false,
    "declarationMap": false,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": [
        "../shared/dist/*"
      ],
      "@/*": [
        "src/*"
      ],
    }
  },
  "include": [
    "src"
  ]
}